FROM oven/bun:1

# Install build dependencies for native modules (node-pty)
# 'make', 'g++', and 'python3' are required for node-gyp to compile C++ code
RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY . .

RUN bun install --frozen-lockfile

EXPOSE 3000

RUN mkdir /workspace

CMD [ "bun", "apps/sandbox/agent/src/index.ts" ]